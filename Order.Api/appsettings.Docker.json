{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "PaymentGateway": {
    "BaseUrl": "http://payment_api:8081/",
    "Mode": "random"
  },
  "Outbox": {
    "MaxParallelism": 4,
    "BatchSize": 10
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=ordersdb;Username=postgres;Password=postgres"
  },
  "Kafka": {
    "BootstrapServers": "kafka:9092",
    "OrdersConfirmedTopic": "orders-confirmed"
  }
}